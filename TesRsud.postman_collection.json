{
	"info": {
		"_postman_id": "tes-rsud-praktikum-laravel-api",
		"name": "TesRsud — Praktikum Laravel API",
		"description": "BAB III — Praktikum Laravel API: Soal 1 (Products), Soal 2 (Orders), Soal 3 (Dashboard)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "order_id",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Test Connection",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/test",
							"host": ["{{base_url}}"],
							"path": ["test"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Soal 1 — Products",
			"item": [
				{
					"name": "GET Semua Produk Aktif",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/products",
							"host": ["{{base_url}}"],
							"path": ["products"]
						}
					},
					"response": []
				},
				{
					"name": "GET Produk — Filter Search",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/products?search=obat",
							"host": ["{{base_url}}"],
							"path": ["products"],
							"query": [
								{ "key": "search", "value": "obat" }
							]
						}
					},
					"response": []
				},
				{
					"name": "GET Produk — Filter Category ID",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/products?category_id=1",
							"host": ["{{base_url}}"],
							"path": ["products"],
							"query": [
								{ "key": "category_id", "value": "1" }
							]
						}
					},
					"response": []
				},
				{
					"name": "GET Produk — Filter Search + Category + Per Page",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/products?search=obat&category_id=1&per_page=5",
							"host": ["{{base_url}}"],
							"path": ["products"],
							"query": [
								{ "key": "search", "value": "obat" },
								{ "key": "category_id", "value": "1" },
								{ "key": "per_page", "value": "5" }
							]
						}
					},
					"response": []
				},
				{
					"name": "GET Produk — Pagination Page 2",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/products?page=2&per_page=10",
							"host": ["{{base_url}}"],
							"path": ["products"],
							"query": [
								{ "key": "page", "value": "2" },
								{ "key": "per_page", "value": "10" }
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Soal 2 — Orders",
			"item": [
				{
					"name": "POST Order — Sukses",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 1,\n    \"qty\": 2\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/orders",
							"host": ["{{base_url}}"],
							"path": ["orders"]
						}
					},
					"response": []
				},
				{
					"name": "POST Order — Validasi: product_id kosong",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"qty\": 2\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/orders",
							"host": ["{{base_url}}"],
							"path": ["orders"]
						}
					},
					"response": []
				},
				{
					"name": "POST Order — Validasi: product tidak ada (404)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 99999,\n    \"qty\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/orders",
							"host": ["{{base_url}}"],
							"path": ["orders"]
						}
					},
					"response": []
				},
				{
					"name": "POST Order — Stok kurang (422)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 1,\n    \"qty\": 99999\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/orders",
							"host": ["{{base_url}}"],
							"path": ["orders"]
						}
					},
					"response": []
				},
				{
					"name": "POST Order — Validasi: qty kurang dari 1",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 1,\n    \"qty\": 0\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/orders",
							"host": ["{{base_url}}"],
							"path": ["orders"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Soal 3 — Dashboard",
			"item": [
				{
					"name": "GET Dashboard Summary (Fresh)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/dashboard/summary",
							"host": ["{{base_url}}"],
							"path": ["dashboard", "summary"]
						}
					},
					"response": []
				},
				{
					"name": "GET Dashboard Summary (From Cache)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/dashboard/summary",
							"host": ["{{base_url}}"],
							"path": ["dashboard", "summary"]
						}
					},
					"response": []
				},
				{
					"name": "DELETE Dashboard Cache (Flush)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/dashboard/cache",
							"host": ["{{base_url}}"],
							"path": ["dashboard", "cache"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Bonus — Scoped Binding",
			"item": [
				{
					"name": "GET Order milik User (Scoped Binding)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/users/{{user_id}}/orders/{{order_id}}",
							"host": ["{{base_url}}"],
							"path": ["users", "{{user_id}}", "orders", "{{order_id}}"]
						}
					},
					"response": []
				},
				{
					"name": "GET Order bukan milik User (404)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/users/1/orders/99999",
							"host": ["{{base_url}}"],
							"path": ["users", "1", "orders", "99999"]
						}
					},
					"response": []
				}
			]
		}
	]
}
